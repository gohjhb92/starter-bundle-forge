# Copy this file to .env.local and paste your key. NEVER commit the real key.
# Get a key at https://console.anthropic.com/ and set a monthly spend cap on it.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Force the free scripted demo (no API calls) even when a key is set.
# DEMO_MODE=1

# --- Optional: production hardening ----------------------------------------
# Upstash Redis makes the per-IP rate limit SHARED across serverless instances
# and the query log persistent. Without these, both fall back to per-instance
# in-memory state (fine locally, weak in production).
# Create a free Redis DB at https://upstash.com and copy its REST credentials.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token

# Enables GET /api/log?token=... to read the query log. Unset = endpoint 404s.
# Use a long random string.
# LOG_TOKEN=your-long-random-secret
